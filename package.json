{
  "name": "cosmo-downloader",
  "version": "1.0.5",
  "description": "Cosmo Downloader",
  "main": "./out/main/index.js",
  "author": "seckinaktunc.com",
  "homepage": "https://github.com/seckinaktunc/cosmo-downloader#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seckinaktunc/cosmo-downloader.git"
  },
  "bugs": {
    "url": "https://github.com/seckinaktunc/cosmo-downloader/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "download:binaries": "node scripts/download-binaries.mjs --all",
    "download:binaries:current": "node scripts/download-binaries.mjs",
    "preflight:win-symlink": "node scripts/preflight-windows-symlink.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/patch-electron-builder-nsis.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && node scripts/patch-electron-builder-nsis.mjs && electron-builder --win",
    "build:win:local": "node scripts/build-windows-local.mjs",
    "verify:win-signing": "node scripts/verify-windows-signing.mjs",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux AppImage --x64 --publish never",
    "build:linux:local": "node scripts/build-linux-local.mjs",
    "verify:linux:package": "node scripts/verify-linux-package.mjs"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@iconify/react": "^6.0.2",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.4",
    "react-i18next": "^17.0.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@iconify-json/flag": "^1.2.12",
    "@iconify-json/logos": "^1.2.11",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.4"
  }
}
